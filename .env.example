DATABASE_URL=postgresql://maestro:changeme@127.0.0.1:5432/maestro_dev
POSTGRES_PASSWORD=changeme
API_KEY_SALT=your-secret-salt-here-change-this
NODE_ENV=development
PORT=3000
ENCRYPTION_KEY=your-32-byte-hex-key-here

# レート制限: 15分あたりの最大リクエスト数（デフォルト: 本番100、dev 1000）
# RATE_LIMIT_MAX=100

# セキュリティメモ:
# - 本APIはAPIキー認証（Bearer トークン）を採用しているため、Cookieベースの CSRF は適用外。
# - CSRF トークンは不要。CORS ホワイトリストで代替保護を実施済み。
# - CORS_ORIGIN に本番ドメインを必ず設定すること（デフォルト: http://localhost:5173）
CORS_ORIGIN=http://localhost:5173

# Google Drive バックアップ（CLI backup create --dest gdrive で使用）
# Google Cloud Console で OAuth2 クライアントID を作成してください
# 認証情報は ~/.maestro/gdrive-token.json に自動保存されます
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
